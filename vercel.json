{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/host",
      "destination": "/host.html"
    },
    {
      "source": "/member",
      "destination": "/member.html"
    },
    {
      "source": "/room",
      "destination": "/member.html"
    }
  ]
}
